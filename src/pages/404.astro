---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <main id="main-content" class="not-found">
    <div class="content">
      <h1 class="heading">Lost in orbit</h1>
      <p class="message">
        The page you're looking for has drifted beyond our reach.
        It may have been moved, renamed, or never existed.
      </p>
      <a href="/" class="back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12" />
          <polyline points="12 19 5 12 12 5" />
        </svg>
        Back to Documentation
      </a>
    </div>
  </main>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 3rem 1rem;
  }

  .content {
    text-align: center;
    max-width: 28rem;
  }

  .heading {
    font-size: 3rem;
    font-weight: 400;
    color: var(--ms-dark);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .message {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--ms-dark) 60%, transparent);
    margin: 0 0 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--ms-blue);
    text-decoration: none;
    padding: 0.625rem 1.25rem;
    border: 1.5px solid color-mix(in srgb, var(--ms-blue) 30%, transparent);
    border-radius: 0.75rem;
    transition: background-color 0.2s, border-color 0.2s;
  }

  .back-link:hover {
    background: color-mix(in srgb, var(--ms-blue) 6%, transparent);
    border-color: color-mix(in srgb, var(--ms-blue) 50%, transparent);
  }

  .back-link:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--ms-blue) 50%, transparent);
    outline-offset: 2px;
  }

  @media (min-width: 640px) {
    .heading {
      font-size: 3.75rem;
    }
  }
</style>

---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import PageHeader from '../../components/PageHeader.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import PrevNext from '../../components/PrevNext.astro';
import DocsHero from '../../components/DocsHero.astro';
import SectionCards from '../../components/SectionCards.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  const allIds = new Set(docs.map((e) => e.id));

  // Build set of directory prefixes to detect section indexes
  const dirPrefixes = new Set<string>();
  for (const id of allIds) {
    const slashIdx = id.lastIndexOf('/');
    if (slashIdx !== -1) {
      dirPrefixes.add(id.substring(0, slashIdx));
    }
  }

  return docs.map((entry) => {
    let slug = entry.id.replace(/\.md$/, '');
    if (slug === 'index') slug = '';
    slug = slug.replace(/\/index$/, '');

    // Determine page type
    const isLandingPage = slug === '';
    const isSectionIndex = !isLandingPage && dirPrefixes.has(entry.id);

    // Collect child pages for section indexes
    let childPages: Array<{ title: string; href: string; description?: string }> = [];
    if (isSectionIndex) {
      childPages = docs
        .filter((e) => {
          // Direct children: starts with this section's id + '/' but no further nesting
          if (!e.id.startsWith(entry.id + '/')) return false;
          const rest = e.id.slice(entry.id.length + 1);
          // Skip sub-indexes and nested items
          if (rest.includes('/')) return false;
          return true;
        })
        .map((e) => {
          let childSlug = e.id.replace(/\.md$/, '');
          childSlug = childSlug.replace(/\/index$/, '');
          return {
            title: e.data.title || childSlug.split('/').pop()!.replace(/[-_]/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
            href: `/docs/${childSlug}`,
            description: e.data.description,
          };
        })
        .sort((a, b) => a.title.localeCompare(b.title));
    }

    return {
      params: { slug: slug || undefined },
      props: { entry, isLandingPage, isSectionIndex, childPages },
    };
  });
}

const { entry, isLandingPage, isSectionIndex, childPages } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(entry);

const title = remarkPluginFrontmatter?.title || entry.data.title || entry.id.replace(/\.md$/, '').split('/').pop() || 'Docs';
const description = remarkPluginFrontmatter?.description || entry.data.description;

let slug = entry.id.replace(/\.md$/, '');
if (slug === 'index') slug = '';
slug = slug.replace(/\/index$/, '');
---

<DocsLayout title={title} headings={headings} slug={slug}>
  <Sidebar slot="sidebar" currentSlug={slug} />

  {isLandingPage && <DocsHero slot="before-content" />}
  {!isLandingPage && <PageHeader slot="before-content" slug={slug} title={title} description={description} />}

  {!isLandingPage && <Content />}

  {!isLandingPage && isSectionIndex && <SectionCards slot="after-content" pages={childPages} />}
  {!isLandingPage && !isSectionIndex && <PrevNext slot="after-content" slug={slug} />}

  {!isLandingPage && !isSectionIndex && <TableOfContents slot="toc" headings={headings} />}
</DocsLayout>

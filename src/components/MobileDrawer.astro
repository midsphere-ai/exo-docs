---
import Sidebar from './Sidebar.astro';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
---

<div class="mobile-drawer-wrapper">
  <input type="checkbox" id="mobile-drawer-toggle" class="drawer-checkbox" aria-hidden="true" />

  <label for="mobile-drawer-toggle" class="drawer-backdrop" aria-hidden="true"></label>

  <div class="drawer-panel">
    <div class="drawer-header">
      <span class="drawer-title">Navigation</span>
      <label for="mobile-drawer-toggle" class="drawer-close" aria-label="Close navigation menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </label>
    </div>
    <div class="drawer-content">
      <Sidebar currentSlug={currentSlug} />
    </div>
  </div>
</div>

<script>
  function initDrawer() {
    const checkbox = document.getElementById('mobile-drawer-toggle') as HTMLInputElement;
    const panel = document.querySelector('.drawer-panel');
    if (checkbox && panel) {
      panel.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('a')) {
          checkbox.checked = false;
        }
      });
    }

    // Update aria-expanded on hamburger when checkbox changes
    const hamburger = document.querySelector('.mobile-hamburger');
    if (checkbox && hamburger) {
      const updateAria = () => {
        hamburger.setAttribute('aria-expanded', String(checkbox.checked));
      };
      checkbox.addEventListener('change', updateAria);
      updateAria();
    }
  }

  initDrawer();
  document.addEventListener('astro:after-swap', initDrawer);
</script>

<style>
  .drawer-checkbox {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  /* Backdrop overlay */
  .drawer-backdrop {
    position: fixed;
    inset: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--ms-dark) 30%, transparent);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    cursor: default;
  }

  /* Drawer panel */
  .drawer-panel {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 45;
    width: 280px;
    max-width: 85vw;
    height: 100vh;
    background: var(--ms-paper);
    border-right: 1px solid color-mix(in srgb, var(--ms-dark) 8%, transparent);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    overflow-y: auto;
  }

  .drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--ms-border);
  }

  .drawer-title {
    font-size: 0.8125rem;
    font-weight: 500;
    color: color-mix(in srgb, var(--ms-dark) 50%, transparent);
  }

  .drawer-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    color: color-mix(in srgb, var(--ms-dark) 50%, transparent);
    cursor: pointer;
    transition: color 0.15s, background-color 0.15s;
  }

  .drawer-close:hover {
    color: var(--ms-dark);
    background: color-mix(in srgb, var(--ms-dark) 6%, transparent);
  }

  .drawer-close:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--ms-blue) 50%, transparent);
    outline-offset: 2px;
  }

  .drawer-content {
    overflow-y: auto;
  }

  /* When checkbox is checked: show backdrop and slide in panel */
  .drawer-checkbox:checked ~ .drawer-backdrop {
    opacity: 1;
    pointer-events: auto;
  }

  .drawer-checkbox:checked ~ .drawer-panel {
    transform: translateX(0);
  }

  /* Hide everything on desktop (md = 768px) */
  @media (min-width: 768px) {
    .drawer-backdrop,
    .drawer-panel {
      display: none;
    }
  }
</style>

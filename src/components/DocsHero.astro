---
const features = [
  {
    name: 'Composable Agents',
    description: 'Build agents from modular pieces. Mix tools, models, and behaviors freely.',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /></svg>',
  },
  {
    name: 'Type-Safe Tools',
    description: 'Define tools with Python type hints. Automatic schema generation and validation.',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>',
  },
  {
    name: 'Three Execution Modes',
    description: 'Workflow chains, handoff routing, and team collaboration out of the box.',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3" /><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83" /></svg>',
  },
  {
    name: 'Multi-Agent Orchestration',
    description: 'Coordinate multiple agents with swarm flows, handoffs, and shared context.',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="3" /><circle cx="5" cy="19" r="3" /><circle cx="19" cy="19" r="3" /><line x1="12" y1="8" x2="5" y2="16" /><line x1="12" y1="8" x2="19" y2="16" /></svg>',
  },
  {
    name: 'Context Engine',
    description: 'Manage state, prompts, knowledge, and token budgets through a unified context.',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" /><polyline points="3.27 6.96 12 12.01 20.73 6.96" /><line x1="12" y1="22.08" x2="12" y2="12" /></svg>',
  },
  {
    name: 'Memory System',
    description: 'Persistent memory backends for long-running agents. Vector, SQL, and file stores.',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3" /><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3" /><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" /></svg>',
  },
];

const exploreLinks = [
  {
    name: 'Getting Started',
    description: 'Install, quickstart, and core concepts',
    href: '/docs/getting-started',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" /></svg>',
  },
  {
    name: 'Guides',
    description: 'In-depth guides for agents, tools, and multi-agent systems',
    href: '/docs/guides',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" /><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" /></svg>',
  },
  {
    name: 'Architecture',
    description: 'System design, execution flow, and package structure',
    href: '/docs/architecture',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" /><line x1="3" y1="9" x2="21" y2="9" /><line x1="9" y1="21" x2="9" y2="9" /></svg>',
  },
  {
    name: 'API Reference',
    description: 'Complete package-by-package API documentation',
    href: '/docs/reference',
    icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" /></svg>',
  },
];
---

<div class="docs-hero">
  <!-- Hero Section -->
  <section class="hero-section" data-animate="reveal">
    <span class="hero-label" data-animate="fade" data-delay="1">Multi-agent framework</span>

    <h1 class="hero-title" data-animate="reveal" data-delay="1">A modern, modular multi-agent framework for building LLM-powered applications in Python.</h1>

    <div class="hero-install" data-animate="fade" data-delay="2">
      <code class="install-command">pip install exo-ai</code>
      <button class="install-copy" aria-label="Copy install command" data-copy="pip install exo-ai">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="copy-icon" aria-hidden="true">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
          <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
        </svg>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-icon" aria-hidden="true">
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </button>
    </div>

    <div class="hero-ctas" data-animate="fade" data-delay="3">
      <a href="/docs/getting-started" class="cta cta-primary">Get Started</a>
      <a href="/docs/getting-started/concepts" class="cta cta-secondary">Core Concepts</a>
    </div>
  </section>

  <!-- Feature Cards -->
  <section class="features-section" data-animate="reveal" data-delay="2">
    <h2 class="section-heading">Built for real-world agents</h2>
    <div class="features-grid">
      {features.map((feature, i) => (
        <div class="feature-card" data-animate="reveal" data-delay={String((i % 6) + 1)}>
          <div class="feature-icon">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="feature-name">{feature.name}</h3>
          <p class="feature-desc">{feature.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Quick Start Code -->
  <section class="quickstart-section" data-animate="fade" data-delay="3">
    <h2 class="section-heading">Get running in minutes</h2>
    <div class="code-block">
      <div class="code-header">
        <span class="code-header-dots">
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot"></span>
        </span>
        <span class="code-header-lang">python</span>
      </div>
      <pre><code><span class="kw">from</span> <span class="mod">exo</span> <span class="kw">import</span> Agent, run, tool

<span class="decorator">@tool</span>
<span class="kw">async def</span> <span class="fn">get_weather</span>(city: <span class="type">str</span>) -> <span class="type">str</span>:
    <span class="str">"""Return the current weather for a city."""</span>
    <span class="kw">return</span> <span class="str">f"Sunny, 22°C in {'{'}<span class="kw">city</span>{'}'}<span class="str">."</span></span>

agent = <span class="type">Agent</span>(
    name=<span class="str">"weather-bot"</span>,
    model=<span class="str">"openai:gpt-4o-mini"</span>,
    tools=[get_weather],
)

result = run.<span class="fn">sync</span>(agent, <span class="str">"What's the weather in Paris?"</span>)
<span class="fn">print</span>(result.text)</code></pre>
    </div>
  </section>

  <!-- Explore the Docs -->
  <section class="explore-section" data-animate="reveal" data-delay="3">
    <h2 class="section-heading">Explore the docs</h2>
    <div class="explore-grid">
      {exploreLinks.map((link, i) => (
        <a href={link.href} class="explore-card" data-animate="reveal" data-delay={String(i + 1)}>
          <div class="explore-icon">
            <Fragment set:html={link.icon} />
          </div>
          <div class="explore-content">
            <h3 class="explore-name">{link.name}</h3>
            <p class="explore-desc">{link.description}</p>
          </div>
          <svg class="explore-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 6 15 12 9 18" />
          </svg>
        </a>
      ))}
    </div>
  </section>
</div>

<script is:inline>
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-copy]');
    if (!btn) return;
    var text = btn.getAttribute('data-copy');
    navigator.clipboard.writeText(text).then(function() {
      btn.classList.add('is-copied');
      setTimeout(function() { btn.classList.remove('is-copied'); }, 2000);
    });
  });
</script>

<style>
  .docs-hero {
    padding: 1rem 0;
  }

  /* Hero Section */
  .hero-section {
    padding: 2rem 0 3rem;
  }

  .hero-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: color-mix(in srgb, var(--ms-dark) 50%, transparent);
    margin-bottom: 0.5rem;
  }

  .hero-title {
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ms-dark);
    max-width: 36rem;
    margin: 0 0 1.5rem;
    line-height: 1.4;
  }

  .hero-install {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: color-mix(in srgb, var(--ms-dark) 4%, transparent);
    border: 1px solid var(--ms-border);
    border-radius: 0.5rem;
    padding: 0.5rem 0.75rem;
    margin-bottom: 1.5rem;
  }

  .install-command {
    font-family: "JetBrains Mono Variable", ui-monospace, SFMono-Regular, monospace;
    font-size: 0.875rem;
    color: var(--ms-dark);
  }

  .install-copy {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border: none;
    background: none;
    color: color-mix(in srgb, var(--ms-dark) 40%, transparent);
    border-radius: 0.25rem;
    cursor: pointer;
    transition: color 200ms, background-color 200ms;
  }

  .install-copy:hover {
    color: var(--ms-dark);
    background: color-mix(in srgb, var(--ms-dark) 8%, transparent);
  }

  .install-copy:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--ms-blue) 50%, transparent);
    outline-offset: 2px;
  }

  .install-copy .check-icon {
    display: none;
  }

  .install-copy.is-copied .copy-icon {
    display: none;
  }

  .install-copy.is-copied .check-icon {
    display: block;
    color: var(--ms-blue);
  }

  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.5rem;
    border-radius: 0.75rem;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: transform 200ms, box-shadow 200ms, background-color 200ms, border-color 200ms;
  }

  .cta:hover {
    transform: scale(1.02);
  }

  .cta:active {
    transform: scale(0.98);
  }

  .cta:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--ms-blue) 50%, transparent);
    outline-offset: 2px;
  }

  .cta-primary {
    background: var(--ms-dark);
    color: var(--ms-paper);
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }

  .cta-primary:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }

  .cta-secondary {
    background: transparent;
    color: var(--ms-dark);
    border: 1px solid var(--ms-border-strong);
  }

  .cta-secondary:hover {
    border-color: color-mix(in srgb, var(--ms-dark) 40%, transparent);
    background: var(--ms-subtle);
  }

  @media (min-width: 640px) {
    .hero-title {
      font-size: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-title {
      font-size: 2.25rem;
    }
  }

  /* Section Headings */
  .section-heading {
    font-family: inherit;
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--ms-dark);
    margin: 0 0 1.5rem;
  }

  /* Feature Cards */
  .features-section {
    padding: 2.5rem 0;
    border-top: 1px solid var(--ms-border);
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .feature-card {
    padding: 1.25rem;
    border: 1px solid var(--ms-border);
    border-radius: 0.75rem;
    background: var(--ms-surface);
    transition: transform 300ms, border-color 300ms, box-shadow 300ms;
  }

  .feature-card:hover {
    transform: translateY(-2px);
    border-color: var(--ms-border-strong);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--ms-dark) 6%, transparent);
  }

  .feature-icon {
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    margin-bottom: 0.75rem;
    color: var(--ms-dark);
    background: color-mix(in srgb, var(--ms-dark) 8%, transparent);
  }

  .feature-name {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--ms-dark);
    margin: 0 0 0.375rem;
  }

  .feature-desc {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: color-mix(in srgb, var(--ms-dark) 60%, transparent);
    margin: 0;
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Quick Start Code */
  .quickstart-section {
    padding: 2.5rem 0;
    border-top: 1px solid var(--ms-border);
  }

  .quickstart-section :global(.code-block) {
    max-width: 36rem;
  }

  .quickstart-section pre {
    padding: 1rem 1.25rem;
    font-size: 0.8125rem;
    line-height: 1.7;
    overflow-x: auto;
  }

  .quickstart-section code {
    font-family: "JetBrains Mono Variable", ui-monospace, SFMono-Regular, monospace;
    color: var(--ms-dark);
  }

  .kw { color: var(--ms-dark); font-weight: 500; }
  .fn { color: var(--ms-blue); }
  .str { color: color-mix(in srgb, var(--ms-dark) 55%, transparent); }
  .type { color: var(--ms-dark); }
  .mod { font-weight: 500; }
  .decorator { color: var(--ms-blue); font-style: italic; }

  /* Explore the Docs */
  .explore-section {
    padding: 2.5rem 0;
    border-top: 1px solid var(--ms-border);
  }

  .explore-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .explore-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--ms-border);
    border-radius: 0.75rem;
    background: var(--ms-surface);
    text-decoration: none;
    color: inherit;
    transition: transform 300ms, border-color 300ms, box-shadow 300ms;
  }

  .explore-card:hover {
    transform: translateY(-2px);
    border-color: var(--ms-border-strong);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--ms-dark) 6%, transparent);
  }

  .explore-card:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--ms-blue) 50%, transparent);
    outline-offset: 2px;
  }

  .explore-icon {
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    color: var(--ms-dark);
    background: color-mix(in srgb, var(--ms-dark) 8%, transparent);
  }

  .explore-content {
    flex: 1;
    min-width: 0;
  }

  .explore-name {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--ms-dark);
    margin: 0 0 0.125rem;
  }

  .explore-desc {
    font-size: 0.8125rem;
    color: color-mix(in srgb, var(--ms-dark) 55%, transparent);
    margin: 0;
  }

  .explore-arrow {
    flex-shrink: 0;
    color: color-mix(in srgb, var(--ms-dark) 30%, transparent);
    transition: color 300ms, transform 300ms;
  }

  .explore-card:hover .explore-arrow {
    color: var(--ms-dark);
    transform: translateX(2px);
  }

  @media (min-width: 640px) {
    .explore-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

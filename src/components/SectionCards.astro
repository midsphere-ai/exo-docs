---
interface ChildPage {
  title: string;
  href: string;
  description?: string;
}

interface Props {
  pages: ChildPage[];
}

const { pages } = Astro.props;

const icons: Record<string, string> = {
  installation: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>',
  quickstart: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" /></svg>',
  concepts: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="16" x2="12" y2="12" /><line x1="12" y1="8" x2="12.01" y2="8" /></svg>',
};

function getIcon(href: string): string {
  const lastSegment = href.split('/').pop() || '';
  return icons[lastSegment] || '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><polyline points="10 9 9 9 8 9" /></svg>';
}
---

{pages.length > 0 && (
  <nav class="section-cards" aria-label="Section pages">
    <div class="section-cards-grid">
      {pages.map((child, i) => (
        <a href={child.href} class="section-card" data-animate="reveal" data-delay={String((i % 6) + 1)}>
          <div class="card-icon">
            <Fragment set:html={getIcon(child.href)} />
          </div>
          <div class="card-content">
            <span class="card-title">{child.title}</span>
            {child.description && (
              <span class="card-desc">{child.description}</span>
            )}
          </div>
          <svg class="card-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 6 15 12 9 18" />
          </svg>
        </a>
      ))}
    </div>
  </nav>
)}

<style>
  .section-cards {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--ms-dark) 8%, transparent);
  }

  .section-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .section-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border: 1px solid color-mix(in srgb, var(--ms-dark) 8%, transparent);
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--ms-surface) 80%, transparent);
    text-decoration: none;
    color: inherit;
    transition: transform 300ms, border-color 300ms, box-shadow 300ms;
  }

  .section-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--ms-dark) 14%, transparent);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--ms-dark) 6%, transparent);
  }

  .section-card:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--ms-blue) 50%, transparent);
    outline-offset: 2px;
  }

  .card-icon {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.375rem;
    color: var(--ms-dark);
    background: color-mix(in srgb, var(--ms-dark) 8%, transparent);
  }

  .card-content {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .card-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--ms-dark);
  }

  .card-desc {
    font-size: 0.8125rem;
    color: color-mix(in srgb, var(--ms-dark) 55%, transparent);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .card-arrow {
    flex-shrink: 0;
    color: color-mix(in srgb, var(--ms-dark) 30%, transparent);
    transition: color 300ms, transform 300ms;
  }

  .section-card:hover .card-arrow {
    color: var(--ms-dark);
    transform: translateX(2px);
  }

  @media (min-width: 640px) {
    .section-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

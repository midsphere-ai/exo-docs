---
import { buildNavTree } from '../utils/navigation';
import type { NavSection, NavItem } from '../utils/navigation';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const sections = await buildNavTree();

function isCurrentPage(item: NavItem): boolean {
  return item.slug === currentSlug;
}

function isSectionActive(section: NavSection): boolean {
  if (section.items.some((item) => item.slug === currentSlug)) return true;
  if (section.children.some((child) => isSectionActive(child))) return true;
  return false;
}

const S = 'stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"';
const I = (d: string) => `<svg class="si" viewBox="0 0 24 24" fill="none" ${S}>${d}</svg>`;

/** Map slug tail (or full slug) → Lucide icon SVG */
const icons: Record<string, string> = {
  // Getting Started
  'installation':      I('<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>'),
  'quickstart':        I('<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>'),
  'concepts':          I('<circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>'),
  'first-agent':       I('<path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/>'),

  'multimodal':        I('<path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>'),
  // Other / top-level
  'changelog':         I('<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>'),
  'migration-guide':   I('<polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>'),
  'from-aworld':       I('<polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>'),
  'design-spec':       I('<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>'),
};

/** Fallback: file-text icon */
const fallbackIcon = I('<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>');

function getIcon(slug: string): string {
  // Try exact last segment first
  const tail = slug.split('/').pop()!;
  if (icons[tail]) return icons[tail];
  // Try full slug
  if (icons[slug]) return icons[slug];
  return fallbackIcon;
}

/** Folder icon for collapsible subsections */
const folderIcon = I('<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>');
---

<div class="sidebar-container">
  <!-- Header: logo -->
  <div class="sidebar-header">
    <a href="/" class="sidebar-logo">
      <span class="sidebar-logo-text">Exo</span>
    </a>
  </div>

  <!-- Search trigger -->
  <div class="sidebar-search-wrap">
    <button type="button" class="sidebar-search-btn" data-search-trigger aria-label="Search documentation">
      <svg class="sidebar-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
      <span class="sidebar-search-label">Search...</span>
      <kbd class="sidebar-search-kbd">⌘K</kbd>
    </button>
  </div>

  <!-- Nav tree -->
  <nav class="sidebar-nav" aria-label="Documentation sidebar">
    {sections.map((section) => (
      <div class="sidebar-group">
        <p class="sidebar-separator">{section.label}</p>

        <ul class="sidebar-list">
          {section.items.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['sidebar-link', { 'is-active': isCurrentPage(item) }]}
                data-active={isCurrentPage(item) ? 'true' : undefined}
                aria-current={isCurrentPage(item) ? 'page' : undefined}
              >
                <Fragment set:html={getIcon(item.slug)} />
                {item.title}
              </a>
            </li>
          ))}

          {section.children.map((child) => (
            <li>
              <details class="sidebar-folder" open={isSectionActive(child)}>
                <summary class="sidebar-folder-label">
                  <Fragment set:html={folderIcon} />
                  <span class="sidebar-folder-text">{child.label}</span>
                  <svg class="sidebar-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="9 6 15 12 9 18" />
                  </svg>
                </summary>
                <ul class="sidebar-list sidebar-list-nested">
                  {child.items.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class:list={['sidebar-link', { 'is-active': isCurrentPage(item) }]}
                        data-active={isCurrentPage(item) ? 'true' : undefined}
                        aria-current={isCurrentPage(item) ? 'page' : undefined}
                      >
                        {item.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>

  <!-- Footer: theme toggle + GitHub -->
  <div class="sidebar-footer">
    <button type="button" class="sidebar-footer-btn theme-toggle" aria-label="Toggle color theme">
      <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5" />
        <line x1="12" y1="1" x2="12" y2="3" />
        <line x1="12" y1="21" x2="12" y2="23" />
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
        <line x1="1" y1="12" x2="3" y2="12" />
        <line x1="21" y1="12" x2="23" y2="12" />
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
      </svg>
      <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
      </svg>
    </button>
    <a href="https://github.com/Midsphere-AI/exo-ai" class="sidebar-footer-btn" target="_blank" rel="noopener noreferrer" aria-label="View on GitHub">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
      </svg>
    </a>
  </div>
</div>

<script>
  function initThemeToggle() {
    document.querySelectorAll<HTMLButtonElement>('.theme-toggle').forEach((toggle) => {
      // Skip if already initialized
      if (toggle.dataset.themeInit) return;
      toggle.dataset.themeInit = 'true';

      toggle.addEventListener('click', () => {
        const html = document.documentElement;
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });
    });
  }

  initThemeToggle();
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>

<style>
  /* ── Container ── */
  .sidebar-container {
    display: flex;
    flex-direction: column;
    height: 100%;
    background-color: var(--ms-paper);
  }

  /* ── Header ── */
  .sidebar-header {
    padding: 0.5rem 1rem 0.25rem;
  }

  .sidebar-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--ms-dark);
  }

  .sidebar-logo:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--ms-blue) 50%, transparent);
    outline-offset: 2px;
    border-radius: 0.375rem;
  }

  .sidebar-logo-icon {
    flex-shrink: 0;
    opacity: 0.8;
  }

  .sidebar-logo-text {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
  }

  /* ── Search ── */
  .sidebar-search-wrap {
    padding: 0 0.75rem 0.5rem;
  }

  .sidebar-search-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.4375rem 0.625rem;
    border: 1px solid var(--ms-border);
    border-radius: 0.5rem;
    background: var(--ms-elevated);
    color: var(--ms-muted);
    font-size: 0.8125rem;
    font-family: inherit;
    cursor: pointer;
    transition: border-color 0.15s, background-color 0.15s;
  }

  .sidebar-search-btn:hover {
    border-color: color-mix(in srgb, var(--ms-dark) 20%, transparent);
    background: var(--ms-surface);
  }

  .sidebar-search-btn:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--ms-blue) 50%, transparent);
    outline-offset: 2px;
  }

  .sidebar-search-icon {
    flex-shrink: 0;
    opacity: 0.6;
  }

  .sidebar-search-label {
    flex: 1;
    text-align: left;
  }

  .sidebar-search-kbd {
    font-family: inherit;
    font-size: 0.6875rem;
    font-weight: 500;
    color: color-mix(in srgb, var(--ms-dark) 35%, transparent);
    background: color-mix(in srgb, var(--ms-dark) 4%, transparent);
    border: 1px solid var(--ms-border);
    border-radius: 0.25rem;
    padding: 0.125rem 0.375rem;
    line-height: 1.4;
  }


---
import BaseLayout from './BaseLayout.astro';
import MobileNavbar from '../components/MobileNavbar.astro';
import MobileDrawer from '../components/MobileDrawer.astro';

interface Props {
  title: string;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  slug: string;
}

const { title, headings = [], slug } = Astro.props;
---

<BaseLayout title={title}>
  <MobileNavbar />
  <MobileDrawer currentSlug={slug} />

  <div class="docs-grid">
    <aside class="docs-sidebar">
      <slot name="sidebar" />
    </aside>

    <main id="main-content" class="docs-content">
      <div class="content-column">
        <slot name="before-content" />
        <div class="prose">
          <slot />
        </div>
        <slot name="after-content" />
      </div>
    </main>

    <aside class="docs-toc">
      <slot name="toc" />
    </aside>
  </div>
</BaseLayout>

<style>
  .docs-grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 100vh;
  }

  .docs-sidebar {
    display: none;
  }

  .docs-toc {
    display: none;
  }

  .docs-content {
    padding: 2rem 1rem;
    overflow: hidden;
  }

  .content-column {
    max-width: 48rem;
    margin: 0 auto;
  }

  /* md breakpoint: sidebar visible, no navbar offset */
  @media (min-width: 768px) {
    .docs-grid {
      grid-template-columns: 268px 1fr;
    }

    .docs-sidebar {
      display: block;
      position: sticky;
      top: 0;
      overflow-y: auto;
      max-height: 100vh;
      border-right: 1px solid var(--ms-border);
    }
  }

  /* lg breakpoint: wider sidebar */
  @media (min-width: 1024px) {
    .docs-grid {
      grid-template-columns: 286px 1fr;
    }
  }

  /* xl breakpoint: TOC appears */
  @media (min-width: 1280px) {
    .docs-grid {
      grid-template-columns: 286px 1fr 220px;
    }

    .docs-toc {
      display: block;
      position: sticky;
      top: 0;
      overflow-y: auto;
      max-height: 100vh;
      border-left: 1px solid var(--ms-border);
    }
  }

  @media (min-width: 640px) {
    .docs-content {
      padding: 2rem 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .docs-content {
      padding: 2rem 2rem;
    }
  }
</style>
